NEXTAUTH_SECRET=change-me-to-a-random-string-in-production
NEXTAUTH_URL=http://localhost:3001

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Telegram OAuth — https://t.me/BotFather
TELEGRAM_BOT_ID=your-bot-id
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# OpenRouter AI — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Resend — email sending — https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=Canonix <noreply@your-domain.com>

# Dev access — enter this code as email on login page to bypass auth (dev only)
DEV_ACCESS_CODE=your-dev-access-code

# Database — PostgreSQL for production
DATABASE_URL=postgresql://user:password@localhost:5432/canonix

# YooKassa — https://yookassa.ru
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Sentry — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
